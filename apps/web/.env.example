# Database connection
DATABASE_URL="postgresql://user:password@localhost:5432/markwrite"

# GitHub OAuth (get from https://github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Optional: force a specific callback URL in production (leave empty to use OAuth app default)
GITHUB_REDIRECT_URI=""
# Required for localhost sign-in: separate OAuth app credentials for local development
GITHUB_LOCAL_CLIENT_ID=""
GITHUB_LOCAL_CLIENT_SECRET=""
GITHUB_LOCAL_REDIRECT_URI="http://localhost:5173/auth/github/callback"

# App URL
PUBLIC_APP_URL="http://localhost:5173"

# Hocuspocus sync server URL
PUBLIC_SYNC_SERVER_URL="ws://localhost:1234"
VITE_SYNC_SERVER_URL="ws://localhost:1234"
