# ==========================================================================
# Sync Server Configuration
# ==========================================================================

# --------------------------------------------------------------------------
# Database
# --------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/markwrite"

# --------------------------------------------------------------------------
# Server
# --------------------------------------------------------------------------
PORT=1234
HOST=0.0.0.0

# --------------------------------------------------------------------------
# CORS
# --------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"

# --------------------------------------------------------------------------
# Authentication
# --------------------------------------------------------------------------
# URL of the web app for session validation
WEB_APP_URL="http://localhost:5173"

# --------------------------------------------------------------------------
# Rate Limiting
# --------------------------------------------------------------------------
MAX_CONNECTIONS_PER_IP=10
MAX_CONNECTIONS_PER_DOCUMENT=50

# --------------------------------------------------------------------------
# Persistence
# --------------------------------------------------------------------------
# Debounce time in milliseconds before persisting changes
DEBOUNCE_MS=2000
# Maximum debounce time before forcing persistence
MAX_DEBOUNCE_MS=10000

# --------------------------------------------------------------------------
# Environment
# --------------------------------------------------------------------------
NODE_ENV=development
